{
  "name": "keyrouter",
  "version": "0.1.0",
  "description": "Self-hosted AI router with OAuth support for GitHub Copilot, OpenAI Codex, and API-key providers",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/canhta/keyrouter.git"
  },
  "homepage": "https://github.com/canhta/keyrouter#readme",
  "bugs": {
    "url": "https://github.com/canhta/keyrouter/issues"
  },
  "keywords": [
    "ai",
    "llm",
    "proxy",
    "router",
    "openai",
    "github-copilot",
    "codex",
    "oauth",
    "openai-compatible",
    "bun"
  ],
  "scripts": {
    "start": "bun run bin/keyrouter.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run typecheck",
    "pre-push": "bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "simple-git-hooks": "^2.13.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "hono": "^4.12.8"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
