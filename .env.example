# keyrouter environment variables
#
# Copy to .env and fill in values.
# Bun automatically loads .env — no dotenv required.

# Server config (optional — defaults shown)
# PORT=3000
# KEYROUTER_NO_OPEN=1   # set to skip auto-opening browser on start

# SQLite database path (defaults to keyrouter.db in cwd)
# KEYROUTER_DB_PATH=./keyrouter.db
